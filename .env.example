# ─── OpenRouter ──────────────────────────────────────────────────────────────
# Required — get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Optional — any model id available on OpenRouter.
# Free options (rate-limited): meta-llama/llama-3.3-70b-instruct:free, deepseek/deepseek-chat-v3.1:free
# Cheap & fast: openai/gpt-4o-mini, google/gemini-2.0-flash-001
OPENROUTER_MODEL=openai/gpt-4o-mini

# Optional — shown on https://openrouter.ai for ranking your app
OPENROUTER_APP_URL=http://localhost:3000
OPENROUTER_APP_NAME=saas-finder

# Optional — tweak network behavior
OPENROUTER_TIMEOUT_MS=90000

# ─── Reddit ──────────────────────────────────────────────────────────────────
# RECOMMENDED — without these you'll hit Reddit's anonymous rate limit (~10 req/min)
# and most multi-subreddit analyses will fail. With OAuth you get 100 req/min.
#
# Setup (2 minutes):
#   1. Go to https://www.reddit.com/prefs/apps
#   2. Click "create another app..." at the bottom
#   3. Pick "installed app" (no client secret needed)
#   4. Name it "saas-finder", set redirect URI to http://localhost:8080
#   5. Copy the client_id (the string just under "personal use script" or "installed app")
REDDIT_CLIENT_ID=
# Only set this if you registered a "web app" or "script" instead of "installed app"
REDDIT_CLIENT_SECRET=

# Optional — Reddit asks for descriptive UA in the form "<platform>:<app>:<version> (by /u/<user>)"
REDDIT_USER_AGENT=web:saas-finder:0.1 (by /u/your-username)

# Optional
REDDIT_TIMEOUT_MS=15000
